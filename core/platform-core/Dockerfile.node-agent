# ---------------------------------------------------------------------------
# node-agent: Lightweight daemon for worker nodes
# Builds from the monorepo root (context: .)
# Reuses platform-core build — the agent is src/node-agent/ within it
# ---------------------------------------------------------------------------

FROM node:22-bookworm-slim AS base
ENV CI=true
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl python3 make g++ && rm -rf /var/lib/apt/lists/*
RUN npm install -g pnpm@10 turbo@2.8.20

# --- Prune the monorepo to only packages needed by platform-core ---
FROM base AS pruner
WORKDIR /app
COPY . .
RUN turbo prune @wopr-network/platform-core --docker \
    && cd out/json \
    && printf "packages:\n" > pnpm-workspace.yaml \
    && find . -mindepth 2 -name "package.json" -exec dirname {} \; | sed 's|^./||' | sort | awk '{print "  - "$0}' >> pnpm-workspace.yaml \
    && cp pnpm-workspace.yaml ../full/pnpm-workspace.yaml

# --- Install dependencies from the pruned lockfile ---
FROM base AS deps
WORKDIR /app
COPY --from=pruner /app/out/json/ .
RUN echo "node-linker=hoisted" > .npmrc && pnpm install --no-frozen-lockfile

# --- Build platform-core (includes node-agent) ---
FROM base AS build
WORKDIR /app
COPY --from=pruner /app/out/full/ .
COPY --from=deps /app/ .
RUN pnpm turbo run build --filter=@wopr-network/platform-core...

# --- Production image ---
FROM node:22-bookworm-slim AS production
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl s3cmd && rm -rf /var/lib/apt/lists/*
WORKDIR /app

# Copy node_modules (hoisted flat layout)
COPY --chown=node:node --from=build /app/node_modules ./node_modules

# Copy built platform-core (contains node-agent dist)
COPY --chown=node:node --from=build /app/core/platform-core/dist ./dist
COPY --chown=node:node --from=build /app/core/platform-core/package.json ./package.json

# Backup + credentials directories
RUN mkdir -p /backups /etc/wopr && chown -R node:node /backups /etc/wopr
VOLUME /backups

USER node

ENV NODE_ENV=production

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "process.exit(0)"

CMD ["node", "dist/node-agent/index.js"]
