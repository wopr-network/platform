{
  "expo": {
    "name": "WOPR",
    "slug": "wopr-mobile",
    "scheme": "wopr",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "bundleIdentifier": "network.wopr.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "network.wopr.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
