{
  "name": "@wopr-network/core-admin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "description": "Internal cross-product admin dashboard — thin Next.js app on @wopr-network/platform-ui-core",
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src/",
