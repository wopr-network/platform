{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "tsconfig*.json",
        "package.json"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "docker:build": {
      "cache": false,
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "src/**",
        "biome.json",
        "../../biome.json"
      ]
    },
    "test": {
      "cache": true,
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "src/**",
        "tests/**",
        "test/**",
        "*.test.ts",
        "*.test.tsx",
        "vitest.config.*"
      ]
    }
  }
}