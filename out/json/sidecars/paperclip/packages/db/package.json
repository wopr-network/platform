{
  "name": "@paperclipai/db",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "generate": "tsc -p tsconfig.json && drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@paperclipai/shared": "workspace:*",
    "drizzle-orm": "^0.38.4",
    "embedded-postgres": "^18.1.0-beta.16",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
