# --- Postgres ---
POSTGRES_USER=core
POSTGRES_PASSWORD=changeme
POSTGRES_DB=platform
DATABASE_URL=postgresql://core:changeme@postgres:5432/platform

# --- Core Server ---
CORE_ALLOWED_SERVICE_TOKENS=core_wopr-ui_xxx,core_paperclip-ui_xxx,core_nemoclaw-ui_xxx,core_holyship-ui_xxx
BETTER_AUTH_SECRET=changeme
PORT=3001

# --- Stripe (shared — per-product keys in product_billing_config table) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Crypto ---
CRYPTO_SERVICE_URL=http://chain-server:3000
CRYPTO_SERVICE_KEY=changeme

# --- Service Tokens ---
WOPR_UI_SERVICE_TOKEN=core_wopr-ui_changeme
PAPERCLIP_UI_SERVICE_TOKEN=core_paperclip-ui_changeme
NEMOCLAW_UI_SERVICE_TOKEN=core_nemoclaw-ui_changeme
HOLYSHIP_SERVICE_TOKEN=core_holyship_changeme
HOLYSHIP_UI_SERVICE_TOKEN=core_holyship-ui_changeme

# --- OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Trusted proxy (Docker bridge default) ---
TRUSTED_PROXY_IPS=172.16.0.0/12
