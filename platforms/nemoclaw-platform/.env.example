# nemoclaw-platform environment variables.
#
# Copy this file and fill in real values:
#   cp .env.example .env
#
# Same docker-compose.yml is used for prod and staging — only this file differs.

# --- Domain ---
DOMAIN=nemopod.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_DEFAULT_PRICE_ID=price_REPLACE_ME
STRIPE_CREDIT_PRICE_5=price_REPLACE_ME
STRIPE_CREDIT_PRICE_10=price_REPLACE_ME
STRIPE_CREDIT_PRICE_25=price_REPLACE_ME
STRIPE_CREDIT_PRICE_50=price_REPLACE_ME
STRIPE_CREDIT_PRICE_100=price_REPLACE_ME

# --- Auth (better-auth) ---
BETTER_AUTH_SECRET=REPLACE_ME
BETTER_AUTH_URL=http://localhost:3100

# --- Email (Resend) ---
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@nemopod.com

# --- Database ---
POSTGRES_PASSWORD=REPLACE_ME
DATABASE_URL=postgresql://nemoclaw:REPLACE_ME@postgres:5432/nemoclaw_platform

# --- Platform Core ---
# Master secret for vault encryption and session signing. Generate: openssl rand -hex 32
PLATFORM_SECRET=REPLACE_ME
# Separate encryption secret for credential encryption at rest. Generate: openssl rand -hex 32
PLATFORM_ENCRYPTION_SECRET=REPLACE_ME

# --- NemoClaw image ---
NEMOCLAW_IMAGE=ghcr.io/wopr-network/nemoclaw:latest

# --- Fleet ---
# FLEET_DATA_DIR=/data/fleet
# FLEET_IMAGE_ALLOWLIST=ghcr.io/wopr-network/nemoclaw:*

# --- Gateway ---
# OPENROUTER_API_KEY=
# NVIDIA_API_KEY=

# --- Margin ---
# MARGIN_CONFIG_JSON={"defaultMargin":1.3,"rules":[]}

# --- Metering ---
# METER_WAL_PATH=/data/meter-wal.jsonl
# METER_DLQ_PATH=/data/meter-dlq.jsonl

# --- OAuth Providers (optional) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
