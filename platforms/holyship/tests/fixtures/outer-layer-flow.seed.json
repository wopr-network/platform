{
  "flows": [
    {
      "name": "outer-test-flow",
      "description": "Flow for outer-layer integration tests",
      "initialState": "open",
      "maxConcurrent": 0,
      "maxConcurrentPerRepo": 0,
      "discipline": "engineering",
      "gateTimeoutMs": 5000
    }
  ],
  "states": [
    { "name": "open", "flowName": "outer-test-flow", "mode": "passive" },
    {
      "name": "working",
      "flowName": "outer-test-flow",
      "mode": "active",
      "promptTemplate": "Do work on {{entity.id}}"
    },
    { "name": "review", "flowName": "outer-test-flow", "mode": "passive" },
    { "name": "done", "flowName": "outer-test-flow", "mode": "passive" },
    { "name": "cancelled", "flowName": "outer-test-flow", "mode": "passive" }
  ],
  "gates": [
    {
      "name": "always-pass",
      "type": "command",
      "command": "gates/test-pass.sh",
      "timeoutMs": 5000
    }
  ],
  "transitions": [
    { "flowName": "outer-test-flow", "fromState": "open", "toState": "working", "trigger": "start", "priority": 0 },
    {
      "flowName": "outer-test-flow",
      "fromState": "working",
      "toState": "review",
      "trigger": "submit",
      "gateName": "always-pass",
      "priority": 0
    },
    { "flowName": "outer-test-flow", "fromState": "review", "toState": "done", "trigger": "approve", "priority": 0 }
  ]
}
