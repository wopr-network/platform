# Required — shared secret for /internal/provision calls between platform and containers
PROVISION_SECRET=change-me-to-a-real-secret

# Required — platform-core inference gateway URL passed to Paperclip containers
GATEWAY_URL=https://api.wopr.network/v1

# Optional — override defaults
# PLATFORM_DOMAIN=localhost
# UI_ORIGIN=http://localhost:3200
# PAPERCLIP_IMAGE=ghcr.io/wopr-network/paperclip:managed
# DATABASE_URL=postgres://user:pass@localhost:5432/paperclip

# Admin auth — API key for /api/admin/* routes (automation/monitoring)
# ADMIN_API_KEY=your-admin-api-key

# Caddy — wildcard TLS reverse proxy
# CADDY_ADMIN_URL=http://caddy:2019
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
