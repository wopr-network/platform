{
  "name": "@wopr-network/paperclip-platform",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "check": "biome check src/ && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@sentry/node": "^10.43.0",
    "@trpc/server": "^11.12.0",
    "@wopr-network/platform-core": "^1.73.0",
    "@wopr-network/provision-client": "^1.0.0",
    "better-auth": "^1.5.4",
    "dockerode": "^4.0.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "lru-cache": "^11.2.6",
    "pg": "^8.20.0",
    "stripe": "^20.4.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/dockerode": "^3.3.35",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "cpu-features",
      "protobufjs",
      "ssh2"
    ]
  }
}