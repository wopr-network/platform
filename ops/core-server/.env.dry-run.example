# Example env file for the local dry-run stack.
# Copy to /home/tsavo/platform/.env.dry-run and customize as needed:
#   cp ops/core-server/.env.dry-run.example .env.dry-run
#
# Almost everything is hardcoded in docker-compose.dry-run.yml (dev-only
# passwords for postgres, fixed Vault AppRole credentials, seeded secrets).
# This file only carries the one value that isn't known at compose-write
# time: the agent registration token minted after core is healthy.

# Minted via:
#   docker compose -f ops/core-server/docker-compose.dry-run.yml --env-file .env.dry-run \
#     exec core node dist/bootstrap-agent.js
#
# Leave blank on the first `up` — spin up postgres + vault + vault-seed +
# core first, then mint the token and fill this in before `up -d node-agent`.
AGENT_REGISTRATION_TOKEN=

# Optional image tag overrides — defaults assume you built with
#   docker build -f platforms/core-server/Dockerfile -t core-server:dev .
#   docker build -f core/platform-core/Dockerfile.node-agent -t node-agent:dev .
CORE_IMAGE=core-server:dev
NODE_AGENT_IMAGE=node-agent:dev
